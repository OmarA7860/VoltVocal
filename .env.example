# Server-only — never exposed to the client (use in Server Actions only).
GROQ_API_KEY=

# Optional — defaults to llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional — max audio upload size in bytes (default 25M, cap 50M)
# MAX_AUDIO_BYTES=26214400

# Optional — company name on exported PDFs (public, embedded in client bundle)
# NEXT_PUBLIC_COMPANY_NAME=Your Company Name
